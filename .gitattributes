* text=auto

*.c text eol=lf
*.h text eol=lf
*.s text eol=lf
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.urdf text eol=lf
*.launch text eol=lf
*.cmake text eol=lf

*.SLDPRT binary
*.SLDASM binary
*.STL binary
*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.docx binary

# Preserve generated/vendor source as imported; do not flag its historical
# alignment whitespace as a repository formatting error.
firmware/** -whitespace
simulation/ros/simulatedrobot/urdf/*.urdf -whitespace
